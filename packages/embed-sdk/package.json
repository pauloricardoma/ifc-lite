{
  "name": "@ifc-lite/embed-sdk",
  "version": "1.14.3",
  "description": "SDK for embedding the IFC-Lite 3D viewer in any web page via iframe",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch"
  },
  "dependencies": {
    "@ifc-lite/embed-protocol": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "license": "MPL-2.0",
  "keywords": [
    "ifc",
    "bim",
    "3d-viewer",
    "embed",
    "iframe",
    "power-bi",
    "superset",
    "grafana"
  ],
  "files": [
    "dist"
  ]
}
